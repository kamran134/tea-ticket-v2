# Database
POSTGRES_DB=teaticket
POSTGRES_USER=teaticket
POSTGRES_PASSWORD=changeme_strong_password

# Backend
DATABASE_URL=postgresql://teaticket:changeme_strong_password@localhost:5432/teaticket
JWT_SECRET=change-this-to-a-long-random-secret
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Admin password hash (bcrypt of admin password)
# Generate: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# Hetzner Object Storage (S3-compatible)
# Endpoint format: https://<region>.your-objectstorage.com
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=tea-ticket-receipts
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# Public base URL of the bucket
S3_PUBLIC_URL=https://tea-ticket-receipts.fsn1.your-objectstorage.com

# Frontend (leave empty in production — uses relative URLs /api/...)
VITE_API_URL=
